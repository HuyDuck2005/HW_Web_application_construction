DB_USER=admin  
DB_PASSWORD=123456  
DB_HOST=localhost  
DB_PORT=15432  
DB_NAME=course_db  
PASSWORD_SALT_ROUNDS=10  
GRPC_ADDRESS=0.0.0.0:50052  
# Cập nhật cho "/services/course-service/.env" (thêm giá trị):
GRPC_HOST=0.0.0.0
GRPC_PORT=50052
HEALTH_PORT=3002

RABBITMQ_URL=amqp://app:app123@localhost:5672
RABBITMQ_EXCHANGE=enrollment.events
RABBITMQ_EXCHANGE_TYPE=topic

RABBITMQ_DLX=enrollment.dlx
COURSE_ENROLLMENT_QUEUE=course.enrollment.confirmed.queue
COURSE_ENROLLMENT_DLQ=course.enrollment.confirmed.dlq
COURSE_ENROLLMENT_ROUTING_KEY=enrollment.confirmed
COURSE_ENROLLMENT_DLQ_ROUTING_KEY=course.enrollment.confirmed.dead
COURSE_EVENTS_EXCHANGE=course.events
COURSE_EVENTS_EXCHANGE_TYPE=topic
COURSE_OUTBOX_POLL_INTERVAL_MS=2000
COURSE_OUTBOX_BATCH_SIZE=20
COURSE_OUTBOX_MAX_ATTEMPTS=10
COURSE_EVENT_MAX_RETRIES=3
COURSE_EVENT_RETRY_DELAY_MS=3000
RABBITMQ_PREFETCH=1